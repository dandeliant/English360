---
interface Item {
  statement: string;
  answer: boolean;
}

interface Props {
  items: Item[];
  /** Stable per-render id so radio names don't collide across panels. */
  scope?: string;
}

const { items, scope = Math.random().toString(36).slice(2, 8) } = Astro.props;
---
<ol class="tf__items">
  {items.map((item, idx) => (
    <li
      class="tf__item"
      data-item
      data-answer={item.answer ? 'true' : 'false'}
    >
      <p class="tf__statement">{item.statement}</p>
      <div class="tf__choices" role="radiogroup" aria-label={`Stwierdzenie ${idx + 1}`}>
        <label class="tf__choice">
          <input
            type="radio"
            name={`tf-${scope}-${idx}`}
            value="true"
            data-input
          />
          <span>True</span>
        </label>
        <label class="tf__choice">
          <input
            type="radio"
            name={`tf-${scope}-${idx}`}
            value="false"
            data-input
          />
          <span>False</span>
        </label>
      </div>
      <span class="tf__feedback" data-feedback aria-live="polite"></span>
    </li>
  ))}
</ol>

<style>
  .tf__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .tf__item {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  @media (max-width: 36rem) {
    .tf__item {
      grid-template-columns: 1fr auto;
      grid-template-areas: 'statement feedback' 'choices choices';
    }
    .tf__statement { grid-area: statement; }
    .tf__choices { grid-area: choices; justify-content: start; }
    .tf__feedback { grid-area: feedback; }
  }

  .tf__item[data-state='correct'] { border-color: var(--success); background: var(--success-bg); }
  .tf__item[data-state='incorrect'] { border-color: var(--error); background: var(--error-bg); }

  .tf__statement {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
  }

  .tf__choices {
    display: flex;
    gap: var(--space-2);
  }

  .tf__choice {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: var(--surface-2);
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    cursor: pointer;
    transition: background-color 100ms ease, border-color 100ms ease;
  }

  .tf__choice:hover { background: var(--border); }

  .tf__choice:has(input:checked) {
    background: var(--accent);
    color: var(--accent-fg);
    border-color: var(--accent);
  }

  .tf__choice input {
    /* Visually hidden but focusable; the label handles the click. */
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .tf__choice:has(input:focus-visible) {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .tf__feedback {
    min-inline-size: 1.5rem;
    text-align: center;
    font-weight: 700;
  }

  .tf__item[data-state='correct'] .tf__feedback { color: var(--success); }
  .tf__item[data-state='incorrect'] .tf__feedback { color: var(--error); }
</style>
