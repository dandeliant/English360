---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LessonCard from '../../components/LessonCard.astro';
import { withBase } from '../../lib/paths.js';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map((lesson) => ({
    params: { id: lesson.id },
    props: { lesson },
  }));
}

interface Props {
  lesson: CollectionEntry<'lessons'>;
}

const { lesson } = Astro.props;
const data = lesson.data;
const title = `${data.title_pl} — ${data.title_en}`;
---
<BaseLayout title={title} description={data.did_you_know?.pl} ogImage={withBase(data.image)}>
  <div class="page">
    <LessonCard lesson={lesson} />
  </div>
</BaseLayout>
