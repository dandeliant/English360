---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildCalendarIndex } from '../utils/calendar-index.ts';
import { withBase } from '../lib/paths.js';

const MONTHS = [
  { en: 'January',   pl: 'Styczeń' },
  { en: 'February',  pl: 'Luty' },
  { en: 'March',     pl: 'Marzec' },
  { en: 'April',     pl: 'Kwiecień' },
  { en: 'May',       pl: 'Maj' },
  { en: 'June',      pl: 'Czerwiec' },
  { en: 'July',      pl: 'Lipiec' },
  { en: 'August',    pl: 'Sierpień' },
  { en: 'September', pl: 'Wrzesień' },
  { en: 'October',   pl: 'Październik' },
  { en: 'November',  pl: 'Listopad' },
  { en: 'December',  pl: 'Grudzień' },
];

// Day-of-week headers. Polish convention is Mon-first (poniedziałek...niedziela).
const WEEKDAYS = [
  { pl: 'Pn', en: 'Mon' },
  { pl: 'Wt', en: 'Tue' },
  { pl: 'Śr', en: 'Wed' },
  { pl: 'Cz', en: 'Thu' },
  { pl: 'Pt', en: 'Fri' },
  { pl: 'So', en: 'Sat' },
  { pl: 'Nd', en: 'Sun' },
];

const today = new Date();
const year = today.getFullYear();
const todayMd = `${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

const calendar = await buildCalendarIndex();

function daysInMonth(y: number, monthNum: number): number {
  return new Date(y, monthNum, 0).getDate();
}

function weekdayIndex(y: number, monthNum: number, d: number): number {
  // Convert JS getDay() (Sun=0..Sat=6) to Mon=0..Sun=6.
  const dow = new Date(y, monthNum - 1, d).getDay();
  return dow === 0 ? 6 : dow - 1;
}

type CalendarMapGet = (typeof calendar)['get'];
type LessonList = NonNullable<ReturnType<CalendarMapGet>>;

type Cell =
  | { kind: 'empty' }
  | { kind: 'day'; day: number; md: string; lessons: LessonList; isToday: boolean };

function buildMonth(monthNum: number): Cell[] {
  const total = daysInMonth(year, monthNum);
  const offset = weekdayIndex(year, monthNum, 1);
  const cells: Cell[] = [];
  for (let i = 0; i < offset; i++) cells.push({ kind: 'empty' });
  for (let d = 1; d <= total; d++) {
    const md = `${String(monthNum).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
    cells.push({
      kind: 'day',
      day: d,
      md,
      lessons: calendar.get(md) ?? [],
      isToday: md === todayMd,
    });
  }
  return cells;
}

const totalLessonsThisYear = [...calendar.values()].length;
---
<BaseLayout
  title={`Kalendarz ${year} · English 360°`}
  description={`Pełny rok lekcji English 360°. Każdy dzień ma swoją lekcję — najedź lub kliknij, by zobaczyć.`}
>
  <div class="page calendar-page">
    <header class="calendar-header">
      <h1 class="calendar-title">Kalendarz <span class="calendar-title__year">{year}</span></h1>
      <p class="calendar-intro">
        Każdy dzień w roku ma swoją własną lekcję. Najedź na podświetlony kwadracik,
        by zobaczyć miniaturę zdjęcia; kliknij, by przejść do lekcji.
      </p>
      <div class="calendar-meta">
        <span class="calendar-meta__pill">
          <strong>{totalLessonsThisYear}</strong> / 365
          <span class="calendar-meta__label">dni z lekcją</span>
        </span>
      </div>
    </header>

    <nav class="calendar-month-nav" aria-label="Przejdź do miesiąca">
      {MONTHS.map((m, idx) => (
        <a href={`#month-${idx + 1}`} class="calendar-month-nav__link">
          <span class="calendar-month-nav__pl">{m.pl}</span>
          <span class="calendar-month-nav__en">{m.en}</span>
        </a>
      ))}
    </nav>

    <div class="calendar-year">
      {MONTHS.map((month, idx) => {
        const monthNum = idx + 1;
        const cells = buildMonth(monthNum);
        const lessonCount = cells.filter((c) => c.kind === 'day' && c.lessons.length > 0).length;
        const totalDays = cells.filter((c) => c.kind === 'day').length;
        return (
          <section class="calendar-month" id={`month-${monthNum}`} aria-labelledby={`month-h-${monthNum}`}>
            <header class="calendar-month__header">
              <h2 class="calendar-month__title" id={`month-h-${monthNum}`}>
                <span class="calendar-month__pl">{month.pl}</span>
                <span class="calendar-month__en">{month.en}</span>
              </h2>
              <span
                class="calendar-month__count"
                aria-label={`${lessonCount} z ${totalDays} dni w miesiącu ma lekcję`}
              >
                {lessonCount}<span class="calendar-month__count-sep">/</span>{totalDays}
              </span>
            </header>

            <ol class="calendar-month__weekdays" aria-hidden="true">
              {WEEKDAYS.map((wd) => (
                <li><abbr title={wd.en}>{wd.pl}</abbr></li>
              ))}
            </ol>

            <ol class="calendar-month__days">
              {cells.map((cell) => {
                if (cell.kind === 'empty') {
                  return <li class="day day--empty" aria-hidden="true"></li>;
                }
                if (cell.lessons.length === 0) {
                  return (
                    <li class:list={['day', cell.isToday && 'day--today']}>
                      <span class="day__num">{cell.day}</span>
                    </li>
                  );
                }
                const primary = cell.lessons[0];
                const date = `${cell.md.slice(0, 2)}.${cell.md.slice(3)}`;
                const multi = cell.lessons.length > 1;
                return (
                  <li
                    class:list={['day', 'day--has-lesson', cell.isToday && 'day--today', multi && 'day--multi']}
                    style={`--day-bg-image: url('${withBase(primary.data.image)}')`}
                  >
                    <a
                      href={withBase(`/lekcja/${primary.id}`)}
                      class="day__link"
                      aria-label={multi
                        ? `${date} — ${primary.data.title_pl} (i ${cell.lessons.length - 1} więcej)`
                        : `${date} — ${primary.data.title_pl}`}
                    >
                      <span class="day__num">{cell.day}</span>
                    </a>
                    {multi && (
                      <span class="day__badge" aria-label={`${cell.lessons.length} lekcji tego dnia`}>{cell.lessons.length}</span>
                    )}
                    <div class="day__preview">
                      {cell.lessons.map((cellLesson) => (
                        <a
                          href={withBase(`/lekcja/${cellLesson.id}`)}
                          class="day__preview-item"
                          aria-label={cellLesson.data.title_pl}
                        >
                          <img src={withBase(cellLesson.data.image)} alt="" loading="lazy" width="224" height="140" />
                          <div class="day__preview-meta">
                            <p class="day__preview-title">{cellLesson.data.title_pl}</p>
                            <p class="day__preview-en">{cellLesson.data.title_en}</p>
                          </div>
                        </a>
                      ))}
                    </div>
                  </li>
                );
              })}
            </ol>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>

<script>
  // On touch devices (no hover), tapping a multi-lesson day cell opens
  // the preview list instead of navigating straight to the primary
  // lesson. Second tap on the same day-link then navigates to primary;
  // a tap on any thumbnail navigates to that specific lesson; a tap
  // anywhere else on the page closes the open preview.
  //
  // On hover-capable devices this whole block is a no-op — the CSS
  // :hover behaviour is unchanged.
  if (window.matchMedia('(hover: none)').matches) {
    const cells = document.querySelectorAll<HTMLElement>('.day--multi');
    cells.forEach((cell) => {
      const link = cell.querySelector<HTMLAnchorElement>('.day__link');
      if (!link) return;
      link.addEventListener('click', (event) => {
        const isOpen = cell.classList.contains('day--preview-open');
        if (!isOpen) {
          event.preventDefault();
          // Close any other open preview first — only one at a time.
          document.querySelectorAll('.day--preview-open').forEach((el) => {
            if (el !== cell) el.classList.remove('day--preview-open');
          });
          cell.classList.add('day--preview-open');
        } else {
          // Second tap on the day-link: close the preview and let the
          // default navigation to the primary lesson happen.
          cell.classList.remove('day--preview-open');
        }
      });
    });

    document.addEventListener('click', (event) => {
      const openCell = document.querySelector<HTMLElement>('.day--preview-open');
      if (!openCell) return;
      const target = event.target;
      if (target instanceof Node && !openCell.contains(target)) {
        openCell.classList.remove('day--preview-open');
      }
    });
  }
</script>

<style>
  .calendar-page {
    max-inline-size: 84rem;
  }

  /* ── Header ────────────────────────────────────────────────── */

  .calendar-header {
    margin-block-end: var(--space-5);
  }

  .calendar-title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    letter-spacing: -0.015em;
  }

  @media (min-width: 48rem) {
    .calendar-title { font-size: var(--text-4xl); }
  }

  .calendar-title__year {
    color: var(--accent);
    font-weight: 400;
  }

  .calendar-intro {
    max-inline-size: var(--content-width);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-muted);
    margin-block: var(--space-3);
  }

  .calendar-meta {
    margin-block-start: var(--space-4);
  }

  .calendar-meta__pill {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .calendar-meta__label {
    font-weight: 400;
    opacity: 0.85;
  }

  /* ── Sticky month nav ─────────────────────────────────────── */

  .calendar-month-nav {
    position: sticky;
    inset-block-start: var(--header-height);
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-block: var(--space-3);
    margin-block-end: var(--space-5);
    border-block: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .calendar-month-nav__link {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.1;
    padding: var(--space-1) var(--space-3);
    min-inline-size: 4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color 100ms ease, color 100ms ease, border-color 100ms ease, transform 100ms ease;
  }

  .calendar-month-nav__link:hover {
    background: var(--accent);
    color: var(--accent-fg);
    border-color: var(--accent);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .calendar-month-nav__pl {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    color: inherit;
  }

  .calendar-month-nav__en {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .calendar-month-nav__link:hover .calendar-month-nav__en {
    color: inherit;
    opacity: 0.85;
  }

  /* ── Year grid ─────────────────────────────────────────────── */

  .calendar-year {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 48rem) {
    .calendar-year { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 75rem) {
    .calendar-year { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Month card ────────────────────────────────────────────── */

  .calendar-month {
    padding: var(--space-4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    scroll-margin-block-start: calc(var(--header-height) + 5rem);
    overflow: visible;
  }

  .calendar-month__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    margin-block-end: var(--space-3);
  }

  .calendar-month__title {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.1;
  }

  .calendar-month__pl {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .calendar-month__en {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .calendar-month__count {
    display: inline-flex;
    align-items: baseline;
    padding: 4px var(--space-3);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .calendar-month__count-sep {
    margin-inline: 1px;
    opacity: 0.5;
    font-weight: 400;
  }

  /* ── Weekday header row + day grid ─────────────────────────── */

  .calendar-month__weekdays,
  .calendar-month__days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
    padding: 0;
    list-style: none;
  }

  .calendar-month__weekdays {
    margin-block-end: var(--space-2);
  }

  .calendar-month__weekdays li {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-faint);
    padding-block: 2px;
  }

  .calendar-month__weekdays abbr {
    text-decoration: none;
    cursor: help;
  }

  /* ── Individual day cells ──────────────────────────────────── */

  .day {
    position: relative;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-2);
    color: var(--text-faint);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: background-color 120ms ease, color 120ms ease, transform 120ms ease;
  }

  .day--empty {
    background: transparent;
    visibility: hidden;
  }

  .day--has-lesson {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent);
    font-weight: 700;
    cursor: pointer;
  }

  /* Thumbnail-as-fog: the lesson photo sits inside the cell, blurred
   * and dimmed so the day number remains readable on top. Image clips
   * to the cell's rounded corners via border-radius: inherit. */
  .day--has-lesson::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--day-bg-image);
    background-size: cover;
    background-position: center;
    filter: blur(1.5px) saturate(0.9);
    opacity: 0.4;
    border-radius: inherit;
    pointer-events: none;
  }

  /* Subtle shadow so the day number stays legible regardless of which
   * colors dominate the photo behind it. */
  .day--has-lesson .day__num {
    text-shadow: 0 1px 3px color-mix(in srgb, var(--bg) 65%, transparent);
  }

  .day--today {
    box-shadow: 0 0 0 2px var(--accent);
    z-index: 1;
  }

  .day--has-lesson:hover {
    background: var(--accent);
    color: var(--accent-fg);
    transform: scale(1.15);
    z-index: 4;
  }

  /* On hover the cell becomes a solid accent chip — hide the foggy
   * thumbnail so the number contrast stays crisp. */
  .day--has-lesson:hover::before {
    opacity: 0;
  }

  .day--has-lesson:hover .day__num {
    text-shadow: none;
  }

  .day__link {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    text-decoration: none;
    border-radius: inherit;
  }

  .day__link:hover,
  .day__link:focus-visible {
    text-decoration: none;
  }

  .day__link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .day__num {
    position: relative;
    z-index: 1;
    pointer-events: none;
  }

  /* ── Multi-lesson badge (2+ lessons on one day) ────────────── */

  .day__badge {
    position: absolute;
    inset-block-start: 2px;
    inset-inline-end: 2px;
    min-inline-size: 1.1rem;
    block-size: 1.1rem;
    padding: 0 4px;
    background: var(--accent);
    color: var(--accent-fg);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 800;
    line-height: 1.1rem;
    text-align: center;
    pointer-events: none;
    box-shadow: 0 1px 3px color-mix(in srgb, var(--bg) 65%, transparent);
    z-index: 2;
  }

  /* ── Hover preview ─────────────────────────────────────────── */

  .day__preview {
    position: absolute;
    inset-inline-start: 50%;
    /* No visual gap: preview visually touches the cell so hover chain
     * survives when the pointer moves from the cell into the preview. */
    inset-block-end: 100%;
    transform: translateX(-50%) translateY(4px);
    width: 14rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 20;
    transition: opacity 160ms ease, visibility 160ms ease, transform 160ms ease;
    /* When many lessons share the day, stack becomes scrollable rather
     * than blowing past the viewport. */
    max-block-size: 24rem;
    overflow-y: auto;
  }

  .day__preview-item {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .day__preview-item:hover {
    background: var(--surface-2);
    text-decoration: none;
  }

  .day__preview-item + .day__preview-item {
    border-block-start: 1px solid var(--border);
  }

  .day__preview img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    background: var(--surface-2);
  }

  .day__preview-meta {
    padding: var(--space-2) var(--space-3) var(--space-3);
  }

  .day__preview-title {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
    line-height: 1.25;
  }

  .day__preview-en {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-block-start: 2px;
    line-height: 1.2;
  }

  @media (hover: hover) and (pointer: fine) {
    .day--has-lesson:hover .day__preview,
    .day--has-lesson:has(.day__preview:hover) .day__preview,
    .day:has(.day__link:focus-visible) .day__preview {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
      pointer-events: auto;
    }
  }

  /* Touch devices: same visible state, toggled by a JS-set class rather
   * than by :hover. First tap opens; a tap outside closes; a tap on a
   * preview item navigates to that specific lesson. */
  .day--preview-open .day__preview {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  /* Preview anchoring: cells in the first row of a month would show
   * a preview that overlaps the month header / sticky nav. Flip those
   * to render below the cell. We approximate "first row" via
   * :nth-of-type — cells 1-7 of any month. */
  .calendar-month__days .day:nth-child(-n + 7) .day__preview {
    inset-block-end: auto;
    inset-block-start: calc(100% + var(--space-2));
    transform: translateX(-50%) translateY(-4px);
  }

  @media (hover: hover) and (pointer: fine) {
    .calendar-month__days .day:nth-child(-n + 7).day--has-lesson:hover .day__preview {
      transform: translateX(-50%) translateY(0);
    }
  }

  /* Right-edge cells: nudge preview leftward so it doesn't clip out. */
  .calendar-month__days .day:nth-child(7n) .day__preview,
  .calendar-month__days .day:nth-child(7n-1) .day__preview {
    inset-inline-start: auto;
    inset-inline-end: 0;
    transform: translateX(0) translateY(4px);
  }

  /* Left-edge cells: nudge preview rightward. */
  .calendar-month__days .day:nth-child(7n+1) .day__preview,
  .calendar-month__days .day:nth-child(7n+2) .day__preview {
    inset-inline-start: 0;
    transform: translateX(0) translateY(4px);
  }
</style>
