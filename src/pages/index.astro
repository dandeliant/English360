---
import BaseLayout from '../layouts/BaseLayout.astro';
import LessonCard from '../components/LessonCard.astro';
import { withBase } from '../lib/paths.js';
import { buildCalendarIndex } from '../utils/calendar-index.ts';

// "Today" at build time. (Static generation: this is frozen until the next
// build. The GitHub Pages workflow runs a monthly cron so the calendar year
// rolls over even without content commits.)
const today = new Date();
const todayIso = today.toISOString().slice(0, 10);
const todayMd = todayIso.slice(5);

// Use the calendar index (MM-DD → Lesson[]) so cross-year siblings are
// grouped together — the calendar's premise is that lessons belong to a
// day-of-year, not to a specific year. If today has any lessons, all of
// them show; if not, we walk backwards day by day looking for the nearest
// past MM-DD that has lessons.
const calendar = await buildCalendarIndex();

let todaysLessons = calendar.get(todayMd) ?? [];
let isFallback = false;
let fallbackMd: string | null = null;

if (todaysLessons.length === 0) {
  const cursor = new Date(today);
  for (let i = 0; i < 366; i++) {
    cursor.setDate(cursor.getDate() - 1);
    const md = `${String(cursor.getMonth() + 1).padStart(2, '0')}-${String(cursor.getDate()).padStart(2, '0')}`;
    const found = calendar.get(md);
    if (found && found.length > 0) {
      todaysLessons = found;
      isFallback = true;
      fallbackMd = md;
      break;
    }
  }
}

if (todaysLessons.length === 0) {
  throw new Error('Brak żadnej lekcji w src/content/lessons/. Dodaj choć jedną.');
}

const primary = todaysLessons[0];
const multi = todaysLessons.length > 1;

const fallbackDateLabel = fallbackMd
  ? `${fallbackMd.slice(3)}.${fallbackMd.slice(0, 2)}` // MM-DD → DD.MM
  : null;

const description = multi
  ? `English 360° — ${todaysLessons.length} lekcje na ${todayIso}: ${todaysLessons.map((l) => l.data.title_pl).join(' · ')}.`
  : `English 360° — lekcja na ${todayIso}: ${primary.data.title_pl}.`;
---
<BaseLayout
  title="Lekcja dnia"
  description={description}
  ogImage={withBase(primary.data.image)}
>
  <div class="page">
    {isFallback && (
      <div class="today-banner" role="status">
        <p>
          <strong>Dziś nie ma nowej lekcji.</strong> Poniżej {multi ? 'lekcje' : 'lekcja'} z najbliższego dnia z zawartością{fallbackDateLabel ? `: ${fallbackDateLabel}` : ''}.
        </p>
      </div>
    )}

    {multi && !isFallback && (
      <div class="today-multi" role="status">
        <p>
          Na dziś przypada <strong>{todaysLessons.length}</strong> {todaysLessons.length < 5 ? 'lekcje' : 'lekcji'} —
          każda z osobnym zdjęciem i osobnym słownictwem. Przewiń w dół, by zobaczyć kolejną.
        </p>
      </div>
    )}

    {multi && isFallback && (
      <div class="today-multi" role="status">
        <p>
          W tym dniu jest <strong>{todaysLessons.length}</strong> {todaysLessons.length < 5 ? 'lekcje' : 'lekcji'} — wszystkie poniżej.
        </p>
      </div>
    )}

    <div class="lessons-stack">
      {todaysLessons.map((lesson) => (
        <LessonCard lesson={lesson} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .today-banner,
  .today-multi {
    margin-block-end: var(--space-5);
    padding: var(--space-3) var(--space-4);
    background: var(--surface-2);
    border-inline-start: 4px solid var(--accent);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--text);
  }

  .lessons-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
</style>
