---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildWordIndex } from '../../utils/word-index.ts';
import { tokenize } from '../../utils/text-tokenize.ts';
import { CEFR_DESCRIPTIONS } from '../../utils/cefr.ts';
import { loadWiktionary } from '../../utils/wiktionary-cache.ts';

export async function getStaticPaths() {
  const index = await buildWordIndex();
  return [...index.values()].map((entry) => ({
    params: { word: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const lessonCount = new Set(entry.occurrences.map((o) => o.lessonId)).size;
const wikt = await loadWiktionary(entry.slug);
const enWiktUrl = `https://en.wiktionary.org/wiki/${encodeURIComponent(entry.lemma)}`;
---
<BaseLayout
  title={`${entry.lemma} · Słownik · English 360°`}
  description={`Słownik English 360°: wszystkie zdania zawierające słowo „${entry.lemma}", z lekcji na różnych poziomach CEFR.`}
>
  <div class="page word-page">
    <p class="word-page__breadcrumb">
      <a href="/slownik">← Słownik</a>
    </p>

    <header class="word-page__header">
      <h1 class="word-page__lemma">{entry.lemma}</h1>
      {entry.ipaBr && (
        <p class="word-page__ipa">
          <span class="ipa">{entry.ipaBr}</span>
          <span class="word-page__ipa-label">brytyjska wymowa</span>
        </p>
      )}
      {entry.translationPl && (
        <p class="word-page__pl">
          <span class="word-page__pl-label">po polsku:</span>
          <strong>{entry.translationPl}</strong>
        </p>
      )}
    </header>

    {wikt?.en && wikt.en.length > 0 && (
      <section class="word-page__section wiktionary wiktionary--en" aria-labelledby="wikt-en-h">
        <h2 id="wikt-en-h" class="word-page__heading">Definicje (Wiktionary EN)</h2>
        {wikt.en.map((part) => (
          <article class="wikt-pos">
            <h3 class="wikt-pos__heading">{part.partOfSpeech}</h3>
            <ol class="wikt-defs">
              {part.definitions.map((def) => (
                <li class="wikt-def">
                  <p class="wikt-def__text">{def.text}</p>
                  {def.examples && def.examples.length > 0 && (
                    <ul class="wikt-def__examples">
                      {def.examples.map((ex) => <li><em>{ex}</em></li>)}
                    </ul>
                  )}
                </li>
              ))}
            </ol>
          </article>
        ))}
        <p class="wiktionary__attribution">
          Źródło: <a href={enWiktUrl} target="_blank" rel="noopener noreferrer">Wiktionary (EN)</a>
          {' · '}licencja <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-SA 4.0</a>
        </p>
      </section>
    )}

    {wikt?.pl && (
      <section class="word-page__section wiktionary wiktionary--pl" aria-labelledby="wikt-pl-h">
        <h2 id="wikt-pl-h" class="word-page__heading">Wikisłownik (PL)</h2>
        <p class="wikt-pl-extract">{wikt.pl.extract}</p>
        <p class="wiktionary__attribution">
          Źródło: <a href={wikt.pl.url} target="_blank" rel="noopener noreferrer">Wikisłownik</a>
          {' · '}licencja <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-SA 4.0</a>
        </p>
      </section>
    )}

    <section class="word-page__section" aria-labelledby="occ-h">
      <h2 id="occ-h" class="word-page__heading">
        W jakich zdaniach się pojawia
      </h2>
      <p class="word-page__meta">
        {entry.occurrences.length} {entry.occurrences.length === 1 ? 'wystąpienie' : entry.occurrences.length < 5 ? 'wystąpienia' : 'wystąpień'}
        w {lessonCount} {lessonCount === 1 ? 'lekcji' : 'lekcjach'}.
      </p>

      <ol class="occurrences">
        {entry.occurrences.map((occ) => (
          <li class="occurrence">
            <p class="occurrence__sentence">
              {tokenize(occ.sentence).map((tok) => {
                if (tok.type !== 'word' || !tok.slug) return tok.text;
                if (tok.slug === entry.slug) {
                  return <mark class="occurrence__match">{tok.text}</mark>;
                }
                return <a class="word-link" href={`/slownik/${tok.slug}`}>{tok.text}</a>;
              })}
            </p>
            <p class="occurrence__source">
              <a href={`/lekcja/${occ.lessonId}`}>{occ.lessonTitlePl}</a>
              <span class="occurrence__sep" aria-hidden="true">·</span>
              <span class={`occurrence__level occurrence__level--${occ.level.toLowerCase()}`}>
                {occ.level} {CEFR_DESCRIPTIONS[occ.level]}
              </span>
              <span class="occurrence__sep" aria-hidden="true">·</span>
              <time datetime={occ.lessonDate}>{occ.lessonDate}</time>
            </p>
          </li>
        ))}
      </ol>
    </section>
  </div>
</BaseLayout>

<style>
  .word-page {
    max-inline-size: var(--content-width);
  }

  .word-page__breadcrumb {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-block-end: var(--space-4);
  }

  .word-page__breadcrumb a {
    color: var(--accent);
  }

  .word-page__header {
    padding-block-end: var(--space-5);
    border-block-end: 1px solid var(--border);
    margin-block-end: var(--space-5);
  }

  .word-page__lemma {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-block-end: var(--space-3);
  }

  .word-page__ipa {
    color: var(--text-muted);
    font-size: var(--text-lg);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .word-page__ipa-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.7;
  }

  .word-page__pl {
    margin-block-start: var(--space-2);
    font-size: var(--text-lg);
  }

  .word-page__pl-label {
    color: var(--text-muted);
    margin-inline-end: var(--space-2);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .word-page__heading {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 700;
    margin-block-end: var(--space-2);
  }

  .word-page__meta {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-block-end: var(--space-5);
  }

  .occurrences {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    counter-reset: occ;
  }

  .occurrence {
    padding: var(--space-4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    counter-increment: occ;
  }

  .occurrence::before {
    content: counter(occ);
    display: inline-block;
    color: var(--text-faint);
    font-size: var(--text-xs);
    font-weight: 700;
    margin-inline-end: var(--space-2);
  }

  .occurrence__sentence {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-block-end: var(--space-3);
    display: inline;
  }

  .occurrence__match {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: var(--accent);
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 3px;
  }

  .occurrence__source {
    font-size: var(--text-sm);
    color: var(--text-muted);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .occurrence__source a { color: var(--accent); }
  .occurrence__sep { opacity: 0.5; }

  .occurrence__level {
    display: inline-flex;
    align-items: center;
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--surface-2);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
  }

  .occurrence__level--a1 { background: var(--level-a1); color: var(--level-a1-fg); }
  .occurrence__level--a2 { background: var(--level-a2); color: var(--level-a2-fg); }
  .occurrence__level--b1 { background: var(--level-b1); color: var(--level-b1-fg); }
  .occurrence__level--b2 { background: var(--level-b2); color: var(--level-b2-fg); }
  .occurrence__level--c1 { background: var(--level-c1); color: var(--level-c1-fg); }
  .occurrence__level--c2 { background: var(--level-c2); color: var(--level-c2-fg); }

  /* ── Wiktionary sections ─────────────────────────────────── */

  .wiktionary {
    margin-block-end: var(--space-6);
    padding: var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .wikt-pos { margin-block-end: var(--space-4); }
  .wikt-pos:last-child { margin-block-end: 0; }

  .wikt-pos__heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-block-end: var(--space-2);
  }

  .wikt-defs {
    padding-inline-start: var(--space-5);
    list-style: decimal;
  }

  .wikt-def {
    margin-block-end: var(--space-3);
  }

  .wikt-def__text {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .wikt-def__examples {
    margin-block-start: var(--space-2);
    padding-inline-start: var(--space-4);
    border-inline-start: 2px solid var(--border);
    list-style: none;
  }

  .wikt-def__examples li {
    font-family: var(--font-serif);
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-block-end: var(--space-1);
  }

  .wikt-pl-extract {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .wiktionary__attribution {
    margin-block-start: var(--space-4);
    padding-block-start: var(--space-3);
    border-block-start: 1px dashed var(--border);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .wiktionary__attribution a { color: var(--text-muted); }
  .wiktionary__attribution a:hover { color: var(--accent); }
</style>
