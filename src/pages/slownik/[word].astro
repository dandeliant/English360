---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildWordIndex } from '../../utils/word-index.ts';
import { tokenize } from '../../utils/text-tokenize.ts';
import { CEFR_DESCRIPTIONS } from '../../utils/cefr.ts';

export async function getStaticPaths() {
  const index = await buildWordIndex();
  return [...index.values()].map((entry) => ({
    params: { word: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const lessonCount = new Set(entry.occurrences.map((o) => o.lessonId)).size;
---
<BaseLayout
  title={`${entry.lemma} · Słownik · English 360°`}
  description={`Słownik English 360°: wszystkie zdania zawierające słowo „${entry.lemma}", z lekcji na różnych poziomach CEFR.`}
>
  <div class="page word-page">
    <p class="word-page__breadcrumb">
      <a href="/slownik">← Słownik</a>
    </p>

    <header class="word-page__header">
      <h1 class="word-page__lemma">{entry.lemma}</h1>
      {entry.ipaBr && (
        <p class="word-page__ipa">
          <span class="ipa">{entry.ipaBr}</span>
          <span class="word-page__ipa-label">brytyjska wymowa</span>
        </p>
      )}
      {entry.translationPl && (
        <p class="word-page__pl">
          <span class="word-page__pl-label">po polsku:</span>
          <strong>{entry.translationPl}</strong>
        </p>
      )}
    </header>

    <section class="word-page__section" aria-labelledby="occ-h">
      <h2 id="occ-h" class="word-page__heading">
        W jakich zdaniach się pojawia
      </h2>
      <p class="word-page__meta">
        {entry.occurrences.length} {entry.occurrences.length === 1 ? 'wystąpienie' : entry.occurrences.length < 5 ? 'wystąpienia' : 'wystąpień'}
        w {lessonCount} {lessonCount === 1 ? 'lekcji' : 'lekcjach'}.
      </p>

      <ol class="occurrences">
        {entry.occurrences.map((occ) => (
          <li class="occurrence">
            <p class="occurrence__sentence">
              {tokenize(occ.sentence).map((tok) => {
                if (tok.type !== 'word' || !tok.slug) return tok.text;
                if (tok.slug === entry.slug) {
                  return <mark class="occurrence__match">{tok.text}</mark>;
                }
                return <a class="word-link" href={`/slownik/${tok.slug}`}>{tok.text}</a>;
              })}
            </p>
            <p class="occurrence__source">
              <a href={`/lekcja/${occ.lessonId}`}>{occ.lessonTitlePl}</a>
              <span class="occurrence__sep" aria-hidden="true">·</span>
              <span class={`occurrence__level occurrence__level--${occ.level.toLowerCase()}`}>
                {occ.level} {CEFR_DESCRIPTIONS[occ.level]}
              </span>
              <span class="occurrence__sep" aria-hidden="true">·</span>
              <time datetime={occ.lessonDate}>{occ.lessonDate}</time>
            </p>
          </li>
        ))}
      </ol>
    </section>
  </div>
</BaseLayout>

<style>
  .word-page {
    max-inline-size: var(--content-width);
  }

  .word-page__breadcrumb {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-block-end: var(--space-4);
  }

  .word-page__breadcrumb a {
    color: var(--accent);
  }

  .word-page__header {
    padding-block-end: var(--space-5);
    border-block-end: 1px solid var(--border);
    margin-block-end: var(--space-5);
  }

  .word-page__lemma {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-block-end: var(--space-3);
  }

  .word-page__ipa {
    color: var(--text-muted);
    font-size: var(--text-lg);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .word-page__ipa-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.7;
  }

  .word-page__pl {
    margin-block-start: var(--space-2);
    font-size: var(--text-lg);
  }

  .word-page__pl-label {
    color: var(--text-muted);
    margin-inline-end: var(--space-2);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .word-page__heading {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 700;
    margin-block-end: var(--space-2);
  }

  .word-page__meta {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-block-end: var(--space-5);
  }

  .occurrences {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    counter-reset: occ;
  }

  .occurrence {
    padding: var(--space-4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    counter-increment: occ;
  }

  .occurrence::before {
    content: counter(occ);
    display: inline-block;
    color: var(--text-faint);
    font-size: var(--text-xs);
    font-weight: 700;
    margin-inline-end: var(--space-2);
  }

  .occurrence__sentence {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-block-end: var(--space-3);
    display: inline;
  }

  .occurrence__match {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: var(--accent);
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 3px;
  }

  .occurrence__source {
    font-size: var(--text-sm);
    color: var(--text-muted);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .occurrence__source a { color: var(--accent); }
  .occurrence__sep { opacity: 0.5; }

  .occurrence__level {
    display: inline-flex;
    align-items: center;
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--surface-2);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
  }

  .occurrence__level--a1 { background: var(--level-a1); color: var(--level-a1-fg); }
  .occurrence__level--a2 { background: var(--level-a2); color: var(--level-a2-fg); }
  .occurrence__level--b1 { background: var(--level-b1); color: var(--level-b1-fg); }
  .occurrence__level--b2 { background: var(--level-b2); color: var(--level-b2-fg); }
  .occurrence__level--c1 { background: var(--level-c1); color: var(--level-c1-fg); }
  .occurrence__level--c2 { background: var(--level-c2); color: var(--level-c2-fg); }
</style>
